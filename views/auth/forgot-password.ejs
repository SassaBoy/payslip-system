<%- include('../partials/header') %>
<style>
  .nm-auth-bg { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #0a1520; padding: 100px 16px 80px; }
  .nm-auth-card { width: 100%; max-width: 440px; background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07); border-radius: 18px; padding: 48px 36px 40px; box-shadow: 0 24px 64px rgba(0,0,0,0.5); }
  .nm-input { display:block; width:100%; padding:11px 13px; background:#112235; border:1px solid rgba(255,255,255,0.07); border-radius:9px; color:#fff; outline:none; }
  .nm-btn-submit { width:100%; padding:12px; border-radius:9px; background:#f5a623; color:#1a0e00; font-weight:700; border:none; cursor:pointer; margin-top:20px; }
  .nm-input-group { position: relative; }
  .nm-input-group .nm-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); }
  .nm-input-group .nm-input { padding-left: 46px !important; }
  input:-webkit-autofill { -webkit-background-clip: text; -webkit-text-fill-color: #fff !important; box-shadow: inset 0 0 20px 20px #112235 !important; }
  
  .nm-alert { padding: 12px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
  .nm-alert-success { background: rgba(34, 197, 94, 0.1); border: 1px solid #22c55e; color: #22c55e; }
  .nm-alert-danger { background: rgba(248, 113, 113, 0.1); border: 1px solid #f87171; color: #f87171; }
</style>

<div class="nm-auth-bg">
  <div class="nm-auth-card">
    <div style="text-align:center; margin-bottom:30px;">
      <h1 style="color:#fff; font-size:1.4rem;">Reset Password</h1>
      <p style="color:rgba(255,255,255,0.4); font-size:0.85rem;">Enter your email to receive a reset link</p>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="nm-alert nm-alert-success">
        <i class="bi bi-check-circle"></i> <%= success[0] %>
      </div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="nm-alert nm-alert-danger">
        <i class="bi bi-exclamation-circle"></i> <%= error[0] %>
      </div>
    <% } %>

    <form action="/forgot-password" method="POST">
      <div class="nm-input-group">
        <i class="bi bi-envelope nm-icon"></i>
        <input type="email" name="email" class="nm-input" placeholder="admin@company.com" required />
      </div>
      <button type="submit" class="nm-btn-submit">Send Reset Link</button>
    </form>
    
    <div style="text-align:center; margin-top:20px;">
      <a href="/login" style="color:#f5a623; text-decoration:none; font-size:0.85rem;">Back to Login</a>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>