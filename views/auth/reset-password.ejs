<%- include('../partials/header') %>
<style>
  .nm-auth-bg {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    background: #0a1520; padding: 100px 16px 80px; box-sizing: border-box;
  }
  .nm-auth-card {
    width: 100%; max-width: 440px; background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 18px; padding: 48px 36px 40px; box-shadow: 0 24px 64px rgba(0,0,0,0.5);
  }
  .nm-input-group { position: relative; margin-bottom: 18px; }
  .nm-input-group .nm-icon {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    color: rgba(255,255,255,0.4); z-index: 2;
  }
  .nm-input {
    display:block; width:100%; padding:11px 13px 11px 46px;
    background:#112235; border:1px solid rgba(255,255,255,0.07);
    border-radius:9px; color:#fff; outline:none;
  }
  .nm-eye {
    position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
    color: rgba(255,255,255,0.5); cursor: pointer; z-index: 3;
  }
  .nm-validation-msg { font-size: 0.78rem; margin-top: 4px; display: block; }
  .nm-btn-submit {
    width:100%; padding:12px; border-radius:9px; background:#f5a623;
    color:#1a0e00; font-weight:700; border:none; cursor:pointer; margin-top:10px;
  }
  /* Autofill Hack */
  input:-webkit-autofill { -webkit-background-clip: text; -webkit-text-fill-color: #fff !important; box-shadow: inset 0 0 20px 20px #112235 !important; }
</style>

<div class="nm-auth-bg">
  <div class="nm-auth-card">
    <div style="text-align:center; margin-bottom:30px;">
      <h1 style="color:#fff; font-size:1.4rem;">New Password</h1>
      <p style="color:rgba(255,255,255,0.4); font-size:0.85rem;">Set your new secure password</p>
    </div>

    <form action="/reset-password/<%= token %>" method="POST" id="resetForm">
      <div class="nm-input-group">
        <i class="bi bi-lock nm-icon"></i>
        <input type="password" name="password" id="password" class="nm-input" placeholder="New Password" required />
        <i class="bi bi-eye-slash nm-eye" id="togglePassword"></i>
        <small id="passwordMsg" class="nm-validation-msg"></small>
      </div>

      <div class="nm-input-group">
        <i class="bi bi-shield-check nm-icon"></i>
        <input type="password" name="confirmPassword" id="confirmPassword" class="nm-input" placeholder="Confirm Password" required />
        <small id="confirmMsg" class="nm-validation-msg"></small>
      </div>

      <button type="submit" class="nm-btn-submit">Update Password</button>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const pw = document.getElementById('password');
  const cpw = document.getElementById('confirmPassword');
  const pwMsg = document.getElementById('passwordMsg');
  const cpwMsg = document.getElementById('confirmMsg');

  // Eye toggle
  document.getElementById('togglePassword').addEventListener('click', function() {
    const isPass = pw.type === 'password';
    pw.type = isPass ? 'text' : 'password';
    this.classList.toggle('bi-eye');
    this.classList.toggle('bi-eye-slash');
  });

  const validate = () => {
    if(pw.value.length > 0) {
      pwMsg.textContent = pw.value.length < 8 ? 'Min 8 characters' : 'Strength: Good ✓';
      pwMsg.style.color = pw.value.length < 8 ? '#f87171' : '#22c55e';
    }
    if(cpw.value.length > 0) {
      cpwMsg.textContent = pw.value === cpw.value ? 'Passwords match ✓' : 'Passwords do not match';
      cpwMsg.style.color = pw.value === cpw.value ? '#22c55e' : '#f87171';
    }
  };

  pw.addEventListener('input', validate);
  cpw.addEventListener('input', validate);
});
</script>