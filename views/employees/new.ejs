<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<style>
  .nm-page-wrapper { flex: 1; padding: 32px 24px 48px; }
  .nm-form-page   { max-width: 860px; margin: 0 auto; }

  .nm-form-header { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; }
  .nm-page-title  { font-family: 'Sora', sans-serif; font-size: 1.5rem; font-weight: 700; color: rgba(255,255,255,0.92); margin: 0; letter-spacing: -0.02em; }
  .nm-page-subtitle { font-size: 0.875rem; color: rgba(255,255,255,0.4); margin: 4px 0 0; }

  /* Autocomplete Styling */
  input:-webkit-autofill,
  input:-webkit-autofill:hover, 
  input:-webkit-autofill:focus {
    -webkit-text-fill-color: rgba(255,255,255,0.92) !important;
    -webkit-box-shadow: 0 0 0px 1000px #112235 inset !important;
    transition: background-color 5000s ease-in-out 0s;
  }

  .nm-back-btn { width: 38px; height: 38px; border-radius: 9px; border: 1px solid rgba(255,255,255,0.07); background: #1a2f45; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.65); text-decoration: none; transition: 0.16s; }
  .nm-back-btn:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.92); }

  .nm-btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 10px 24px; border-radius: 9px; background: #f5a623; color: #1a0e00; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; font-weight: 700; border: none; cursor: pointer; transition: 0.2s; }
  .nm-btn-primary:hover { background: #e8981e; transform: translateY(-1px); box-shadow: 0 4px 15px rgba(245,166,35,0.2); }
  .nm-btn-ghost { padding: 9px 18px; border-radius: 9px; border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.65); text-decoration: none; font-size: 0.875rem; transition: 0.16s; }
  .nm-btn-ghost:hover { background: rgba(255,255,255,0.04); color: #fff; }

  .nm-form-card { background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; margin-bottom: 24px; overflow: hidden; }
  .nm-form-card-header { display: flex; align-items: center; gap: 10px; padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.07); font-weight: 600; color: rgba(255,255,255,0.92); background: #112235; font-family: 'Sora', sans-serif; }
  .nm-form-card-body { padding: 24px; }

  .nm-label { display: block; font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,0.5); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.03em; }
  .nm-required { color: #f5a623; margin-left: 2px; }
  
  .nm-input { display: block; width: 100%; padding: 10px 14px; background: #112235; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #fff; font-size: 0.9rem; transition: 0.2s; outline: none; }
  .nm-input:focus { border-color: #f5a623; background: #162a41; box-shadow: 0 0 0 3px rgba(245,166,35,0.08); }

  .nm-input-group { display: flex; align-items: stretch; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); transition: 0.2s; }
  .nm-input-group:focus-within { border-color: #f5a623; box-shadow: 0 0 0 3px rgba(245,166,35,0.08); }
  .nm-input-prefix { background: #1a2f45; padding: 0 14px; display: flex; align-items: center; color: rgba(255,255,255,0.4); font-weight: 700; border-right: 1px solid rgba(255,255,255,0.1); font-size: 0.85rem; }
  .nm-input-group .nm-input { border: none; border-radius: 0; }

  .nm-error-banner { display: none; background: rgba(248,113,113,0.1); border: 1px solid #f87171; color: #f87171; padding: 12px; border-radius: 10px; margin-bottom: 20px; font-size: 0.85rem; }
  .nm-hint { font-size: 0.775rem; color: rgba(255,255,255,0.3); margin-top: 6px; }
/* Password Toggle Styling */
  .nm-password-wrapper { position: relative; }
  .nm-password-toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255,255,255,0.4);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }
  .nm-password-toggle:hover { color: #f5a623; }
  .nm-password-wrapper .nm-input { padding-right: 40px; }
</style>

<div class="nm-page-wrapper">
  <div class="nm-form-page">

    <div class="nm-form-header">
      <a href="/employees" class="nm-back-btn"><i class="bi bi-arrow-left"></i></a>
      <div>
        <h1 class="nm-page-title">Add New Employee</h1>
        <p class="nm-page-subtitle">Standardized Namibian Payroll Entry</p>
      </div>
    </div>

    <div id="duplicateError" class="nm-error-banner">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <strong>Duplicate ID:</strong> This Namibian ID is already registered in the system.
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="nm-error-banner" style="display: block;">
        <% errors.forEach(e => { %> <div><%= e.msg %></div> <% }) %>
      </div>
    <% } %>

    <form action="/employees" method="POST" id="employeeForm">
      
      <div class="nm-form-card">
        <div class="nm-form-card-header"><i class="bi bi-person-fill me-2"></i> Personal Details</div>
        <div class="nm-form-card-body">
          <div class="row g-4">
            <div class="col-md-6">
              <label class="nm-label">Full Name <span class="nm-required">*</span></label>
              <input type="text" name="fullName" class="nm-input" value="<%= formData.fullName || '' %>" placeholder="Johannes Nghifikepunye" required autofocus />
            </div>
            <div class="col-md-6">
              <label class="nm-label">Namibian ID Number <span class="nm-required">*</span></label>
              <input type="text" name="idNumber" id="idNumberField" class="nm-input" value="<%= formData.idNumber || '' %>" placeholder="95010100000" required />
            </div>
            <div class="col-md-6">
              <label class="nm-label">Email Address <span class="nm-required">*</span></label>
              <input type="email" name="email" class="nm-input" value="<%= formData.email || '' %>" placeholder="employee@company.com" required />
            </div>
            <div class="col-md-6">
              <label class="nm-label">Phone Number</label>
              <div class="nm-input-group">
                <span class="nm-input-prefix">+264</span>
                <input type="tel" name="phone" class="nm-input" value="<%= formData.phone || '' %>" placeholder="81 000 0000" />
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="nm-form-card">
        <div class="nm-form-card-header"><i class="bi bi-briefcase-fill me-2"></i> Employment Details</div>
        <div class="nm-form-card-body">
          <div class="row g-4">
            <div class="col-md-6">
              <label class="nm-label">Position / Job Title</label>
              <input type="text" name="position" class="nm-input" value="<%= formData.position || '' %>" placeholder="e.g. Farm Manager" />
            </div>
            <div class="col-md-6">
              <label class="nm-label">Department</label>
              <input type="text" name="department" class="nm-input" value="<%= formData.department || '' %>" placeholder="e.g. Operations" />
            </div>
            <div class="col-md-6">
              <label class="nm-label">Basic Monthly Salary (NAD) <span class="nm-required">*</span></label>
              <div class="nm-input-group">
                <span class="nm-input-prefix">N$</span>
                <input type="number" name="basicSalary" class="nm-input" step="0.01" value="<%= formData.basicSalary || '' %>" placeholder="0.00" required />
              </div>
            </div>
            <div class="col-md-6">
              <label class="nm-label">Date Joined <span class="nm-required">*</span></label>
              <input type="date" name="dateJoined" id="dateJoined" class="nm-input" value="<%= formData.dateJoined ? new Date(formData.dateJoined).toISOString().split('T')[0] : '' %>" required />
            </div>
          </div>
        </div>
      </div>

      <div class="nm-form-card">
        <div class="nm-form-card-header"><i class="bi bi-calendar-check-fill me-2"></i> Leave Balances</div>
        <div class="nm-form-card-body">
          <div class="row g-4">
            <div class="col-md-6">
              <label class="nm-label">Annual Leave Balance (days)</label>
              <input type="number" name="annualLeaveBalance" class="nm-input" min="0" value="<%= formData.annualLeaveBalance !== undefined ? formData.annualLeaveBalance : 24 %>" />
              <div class="nm-hint">Standard default: 24 days</div>
            </div>
            <div class="col-md-6">
              <label class="nm-label">Sick Leave Balance (days)</label>
              <input type="number" name="sickLeaveBalance" class="nm-input" min="0" value="<%= formData.sickLeaveBalance !== undefined ? formData.sickLeaveBalance : 30 %>" />
              <div class="nm-hint">Standard default: 30 days</div>
            </div>
          </div>
        </div>
      </div>

    <div class="nm-form-card">
        <div class="nm-form-card-header"><i class="bi bi-shield-lock-fill me-2"></i> Employee Portal Access</div>
        <div class="nm-form-card-body">
          <p class="nm-hint mb-3">Optional: Setting a password enables the employee to log in and download their own payslips.</p>
          <div class="col-md-6">
            <label class="nm-label">Initial Portal Password</label>
            <div class="nm-password-wrapper">
              <input type="password" name="portalPassword" id="portalPassword" class="nm-input" placeholder="Minimum 6 characters" />
              <button type="button" class="nm-password-toggle" onclick="togglePassword()">
                <i class="bi bi-eye-slash" id="toggleIcon"></i>
              </button>
            </div>
            <div class="nm-hint">The employee will be asked to verify their email upon first login.</div>
          </div>
        </div>
      </div>

      <div class="nm-form-actions">
        <button type="submit" class="nm-btn-primary" id="submitBtn">
          <i class="bi bi-check-circle-fill"></i> Add Employee
        </button>
        <a href="/employees" class="nm-btn-ghost">Cancel and Return</a>
      </div>
    </form>
  </div>
</div>

<script>
  // 1. DUPLICATE ID DATA
  const existingIDs = <%- JSON.stringify(employees.map(e => e.idNumber)) %>;

  const idField = document.getElementById('idNumberField');
  const errorBanner = document.getElementById('duplicateError');
  const submitBtn = document.getElementById('submitBtn');
  const dateField = document.getElementById('dateJoined');

  // 2. SET DEFAULT DATE
  if (!dateField.value) dateField.valueAsDate = new Date();

  // 3. REAL-TIME VALIDATION
  idField.addEventListener('input', function() {
    const val = this.value.trim();
    if (val !== "" && existingIDs.includes(val)) {
      errorBanner.style.display = 'block';
      this.style.borderColor = '#f87171';
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.4';
    } else {
      errorBanner.style.display = 'none';
      this.style.borderColor = '';
      submitBtn.disabled = false;
      submitBtn.style.opacity = '1';
    }
  });

  // 4. ENTER KEY NAVIGATION
  const inputs = Array.from(document.querySelectorAll('.nm-input'));
  inputs.forEach((input, index) => {
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        if (index < inputs.length - 1 && input.type !== 'submit') {
          e.preventDefault();
          inputs[index + 1].focus();
        }
      }
    });
  });

 function togglePassword() {
  const passwordInput = document.getElementById('portalPassword');
  const toggleIcon = document.getElementById('toggleIcon');
  
  if (passwordInput.type === 'password') {
    passwordInput.type = 'text';
    // Password is now VISIBLE - show the OPEN eye
    toggleIcon.classList.remove('bi-eye-slash');
    toggleIcon.classList.add('bi-eye');
  } else {
    passwordInput.type = 'password';
    // Password is now HIDDEN - show the SLASHED eye
    toggleIcon.classList.remove('bi-eye');
    toggleIcon.classList.add('bi-eye-slash');
  }
}
</script>

<%- include('../partials/footer') %>