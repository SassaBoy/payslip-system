<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<style>
  .nm-page-wrapper { flex:1; padding:32px 24px 48px; }
  .nm-page-inner   { max-width:1400px; margin:0 auto; }

  .nm-form-header { display:flex; align-items:center; gap:16px; margin-bottom:28px; }
  .nm-back-btn { width:38px; height:38px; border-radius:9px; border:1px solid rgba(255,255,255,0.07); background:#1a2f45; display:flex; align-items:center; justify-content:center; color:rgba(255,255,255,0.65); text-decoration:none; flex-shrink:0; transition: 0.16s; }
  .nm-back-btn:hover { background:rgba(255,255,255,0.08); color:rgba(255,255,255,0.92); }
  .nm-page-title    { font-family:'Sora',sans-serif; font-size:1.5rem; font-weight:700; color:rgba(255,255,255,0.92); margin:0; letter-spacing:-0.02em; }
  .nm-page-subtitle { font-size:0.875rem; color:rgba(255,255,255,0.4); margin:5px 0 0; }

  .nm-btn-primary { display:inline-flex; align-items:center; gap:8px; padding:9px 20px; border-radius:9px; background:#f5a623; color:#1a0e00; font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; border:none; cursor:pointer; transition: 0.16s; }
  .nm-btn-primary:hover { background:#e8981e; transform:translateY(-1px); }
  .nm-btn-ghost { padding:8px 16px; color:rgba(255,255,255,0.4); text-decoration:none; font-size:0.82rem; transition:0.16s; border-radius:8px; border: none; background: transparent; cursor: pointer; }
  .nm-btn-ghost:hover { background:rgba(255,255,255,0.05); color:#fff; }
  
  .nm-panel { background:#0d1b2a; border:1px solid rgba(255,255,255,0.07); border-radius:14px; overflow:hidden; margin-bottom:20px; }
  .nm-panel-header { display:flex; align-items:center; justify-content:space-between; padding:14px 20px; border-bottom:1px solid rgba(255,255,255,0.07); background:#112235; }
  
  .nm-table { width:100%; border-collapse:collapse; font-size:0.82rem; }
  .nm-table thead th { padding:12px 14px; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.06em; color:rgba(255,255,255,0.35); background:#112235; border-bottom:1px solid rgba(255,255,255,0.07); text-align:left; }
  .nm-table td { padding:14px 14px; vertical-align: top; border-bottom:1px solid rgba(255,255,255,0.04); }

  /* Duplicate Highlighting */
  .emp-row.is-duplicate { background: rgba(239, 68, 68, 0.08) !important; }
  .duplicate-badge { display: none; color: #ef4444; font-size: 0.65rem; font-weight: 700; margin-top: 4px; text-transform: uppercase; }
  .is-duplicate .duplicate-badge { display: block; }

  .nm-label { font-size:0.7rem; text-transform:uppercase; color:rgba(255,255,255,0.3); margin-bottom:6px; display:block; font-weight:600; }
  .nm-emp-name { font-weight:600; color:rgba(255,255,255,0.88); font-size:0.85rem; margin-top: 2px; }
  .nm-salary   { font-family:'Sora',sans-serif; font-weight:600; color:#60a5fa; white-space:nowrap; margin-top: 2px; }

  .nm-input { width:100%; padding:8px 10px; background:#0a141f; border:1px solid rgba(255,255,255,0.1); border-radius:6px; color:#fff; font-size:0.85rem; outline:none; transition:0.16s; }
  .nm-input:focus { border-color:#f5a623; background:#112235; box-shadow: 0 0 0 2px rgba(245,166,35,0.1); }
  .nm-input.allowance { border-color: rgba(52, 211, 153, 0.2); color: #34d399; }
  .nm-input.deduction { border-color: rgba(248, 113, 113, 0.2); color: #f87171; }
  
  .nm-bal { font-size:0.68rem; color:rgba(255,255,255,0.25); margin-top:6px; font-style: italic; }
  .nm-submit-bar { position: sticky; bottom: 20px; display:flex; align-items:center; gap:12px; margin-top:20px; background: #1a2f45; padding: 16px; border-radius: 12px; border: 1px solid rgba(245,166,35,0.3); box-shadow: 0 10px 30px rgba(0,0,0,0.5); z-index: 100; }
</style>

<div class="nm-page-wrapper">
  <div class="nm-page-inner">

    <div class="nm-form-header">
      <a href="/payroll" class="nm-back-btn"><i class="bi bi-arrow-left"></i></a>
      <div>
        <h1 class="nm-page-title">Run Payroll</h1>
        <p class="nm-page-subtitle">Batch Entry: <%= months.find(m=>m.value===selectedMonth).name %> <%= selectedYear %></p>
      </div>
    </div>

    <div id="importStatusAlert" style="display:none;" class="alert alert-info py-2 px-3 border-0 rounded-3 mb-3 small"></div>

    <div class="d-flex justify-content-between align-items-end mb-4 gap-3">
      <div class="nm-panel m-0" style="max-width: 450px; flex: 1;">
        <div class="nm-panel-body py-2 px-3">
          <form method="GET" action="/payroll/run" class="row g-2 align-items-end">
            <div class="col"><select name="month" class="nm-input"><% months.forEach(m => { %><option value="<%= m.value %>" <%= m.value === selectedMonth ? 'selected' : '' %>><%= m.name %></option><% }) %></select></div>
            <div class="col"><select name="year" class="nm-input"><% years.forEach(y => { %><option value="<%= y %>" <%= y === selectedYear ? 'selected' : '' %>><%= y %></option><% }) %></select></div>
            <div class="col-auto"><button type="submit" class="nm-btn-primary" style="padding: 7px 15px;">Load</button></div>
          </form>
        </div>
      </div>
      
      <div class="d-flex gap-2 mb-1">
        <button type="button" onclick="downloadTemplate()" class="nm-btn-ghost"><i class="bi bi-download me-1"></i> Template</button>
        <button type="button" class="nm-btn-primary" onclick="document.getElementById('csvInput').click()">
          <i class="bi bi-file-earmark-excel"></i> Bulk Import CSV
        </button>
        <input type="file" id="csvInput" style="display: none;" accept=".csv" onchange="handleCSV(this)">
      </div>
    </div>

    <% if (employees.length > 0) { %>
    <form action="/payroll/run" method="POST" id="payrollForm">
      <input type="hidden" name="month" value="<%= selectedMonth %>" />
      <input type="hidden" name="year" value="<%= selectedYear %>" />

      <div class="nm-panel">
        <div class="nm-panel-header">
          <div class="nm-panel-title"><i class="bi bi-people-fill text-info"></i> Payroll Entry List</div>
          <div class="text-muted small" id="autosaveStatus">All changes saved</div>
        </div>

        <div class="table-responsive">
          <table class="nm-table" id="entryTable">
            <thead>
              <tr>
                <th style="width: 240px;">Employee</th>
                <th style="width: 130px;">Basic Salary</th>
                <th>Taxable Allow.</th>
                <th>Non-Tax Allow.</th>
                <th>Other Deduct.</th>
                <th style="width: 80px;">OT (Hrs)</th>
                <th style="width: 210px;">Leave Days</th>
              </tr>
            </thead>
            <tbody>
              <% employees.forEach(emp => { %>
                <tr class="emp-row" data-id-number="<%= emp.idNumber %>">
                  <td>
                    <div class="nm-emp-name"><%= emp.fullName %></div>
                    <div class="nm-bal">ID: <span class="row-id-display"><%= emp.idNumber %></span></div>
                    <div class="duplicate-badge"><i class="bi bi-exclamation-triangle"></i> Duplicate ID Found</div>
                  </td>
                  <td><div class="nm-salary">N$ <%= emp.basicSalary.toLocaleString() %></div></td>
                  <td><input type="number" name="employees[<%= emp._id %>][taxableAllowances]" data-key="tax-<%= emp._id %>" data-match="<%= emp.idNumber %>" class="nm-input allowance payroll-field" value="0" step="0.01"></td>
                  <td><input type="number" name="employees[<%= emp._id %>][nonTaxableAllowances]" data-key="ntax-<%= emp._id %>" data-match="<%= emp.idNumber %>" class="nm-input allowance payroll-field" value="0" step="0.01"></td>
                  <td><input type="number" name="employees[<%= emp._id %>][otherDeductions]" data-key="ded-<%= emp._id %>" data-match="<%= emp.idNumber %>" class="nm-input deduction payroll-field" value="0" step="0.01"></td>
                  <td><input type="number" name="employees[<%= emp._id %>][overtimeHours]" data-key="ot-<%= emp._id %>" data-match="<%= emp.idNumber %>" class="nm-input payroll-field" value="0" step="0.5"></td>
                  <td>
                    <div class="d-flex gap-2">
                      <div style="flex:1">
                        <input type="number" name="employees[<%= emp._id %>][annualLeaveTaken]" data-key="ann-<%= emp._id %>" data-match="<%= emp.idNumber %>" class="nm-input payroll-field" value="0" step="0.5" placeholder="Ann.">
                        <div class="nm-bal">Bal: <%= emp.annualLeaveBalance %>d</div>
                      </div>
                      <div style="flex:1">
                        <input type="number" name="employees[<%= emp._id %>][sickLeaveTaken]" data-key="sick-<%= emp._id %>" data-match="<%= emp.idNumber %>" class="nm-input payroll-field" value="0" step="0.5" placeholder="Sick">
                        <div class="nm-bal">Bal: <%= emp.sickLeaveBalance %>d</div>
                      </div>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="nm-submit-bar">
        <button type="submit" class="nm-btn-primary" id="runPayrollBtn">Process Payroll</button>
        <button type="button" class="nm-btn-ghost ms-auto" onclick="clearDraft()">Reset Form</button>
      </div>
    </form>
    <% } %>
  </div>
</div>

<script>
  const STORAGE_KEY = 'payroll_draft_<%= selectedMonth %>_<%= selectedYear %>';

  // --- 1. DUPLICATE ID DETECTION ---
  function checkDuplicates() {
    const ids = {};
    document.querySelectorAll('.emp-row').forEach(row => {
      const id = row.getAttribute('data-id-number');
      ids[id] = (ids[id] || 0) + 1;
    });

    document.querySelectorAll('.emp-row').forEach(row => {
      const id = row.getAttribute('data-id-number');
      if (ids[id] > 1) {
        row.classList.add('is-duplicate');
      } else {
        row.classList.remove('is-duplicate');
      }
    });
  }

  // --- 2. IMPROVED CSV IMPORT (Match by ID Number) ---
  function handleCSV(input) {
    const reader = new FileReader();
    reader.onload = function() {
      const lines = reader.result.split('\n');
      const header = lines[0].toLowerCase();
      
      // Validation: Ensure the file has the correct ID column
      if (!header.includes('id number') && !header.includes('employeeid')) {
        alert('Invalid CSV: Please ensure the first column header is "ID Number"');
        return;
      }

      let matchCount = 0;
      let failCount = 0;

      lines.slice(1).forEach(line => {
        const parts = line.split(',');
        if (parts.length < 2) return;

        const idNum = parts[0].trim();
        const data = parts.slice(1); // [tax, ntax, ded, ot, ann, sick]

        // Find all inputs that match this ID Number
        const targetInputs = document.querySelectorAll(`input[data-match="${idNum}"]`);
        
        if (targetInputs.length > 0) {
          matchCount++;
          // Filter inputs by type and update
          updateFieldGroup(idNum, 'tax-', data[0]);
          updateFieldGroup(idNum, 'ntax-', data[1]);
          updateFieldGroup(idNum, 'ded-', data[2]);
          updateFieldGroup(idNum, 'ot-', data[3]);
          updateFieldGroup(idNum, 'ann-', data[4]);
          updateFieldGroup(idNum, 'sick-', data[5]);
        } else {
          failCount++;
        }
      });

      const status = document.getElementById('importStatusAlert');
      status.style.display = 'block';
      status.innerHTML = `<strong>Import Result:</strong> Matched ${matchCount} records. ${failCount > 0 ? failCount + ' IDs were not found in this list.' : ''}`;
    };
    reader.readAsText(input.files[0]);
  }

  function updateFieldGroup(idNum, keyPrefix, value) {
    if (value === undefined || value === "") return;
    // We look for any input where the data-match is the ID number and data-key starts with our prefix
    document.querySelectorAll(`input[data-match="${idNum}"]`).forEach(input => {
        if (input.dataset.key.startsWith(keyPrefix)) {
            input.value = value.trim();
            input.dispatchEvent(new Event('input'));
        }
    });
  }

  function downloadTemplate() {
    let csv = "ID Number,Taxable_Allow,NonTax_Allow,Deductions,OT_Hrs,Annual_Leave,Sick_Leave\n";
    <% employees.forEach(emp => { %>
      csv += "<%= emp.idNumber %>,0,0,0,0,0,0\n";
    <% }) %>
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = "payroll_template.csv";
    a.click();
  }

  // --- 3. KEYBOARD NAV & AUTOSAVE ---
  window.addEventListener('load', () => {
    checkDuplicates();
    const savedData = JSON.parse(localStorage.getItem(STORAGE_KEY));
    if (savedData) {
      Object.keys(savedData).forEach(key => {
        const input = document.querySelector(`[data-key="${key}"]`);
        if (input) input.value = savedData[key];
      });
    }
  });

  document.getElementById('payrollForm')?.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      const active = document.activeElement;
      if (active.classList.contains('payroll-field')) {
        e.preventDefault();
        const currentTd = active.closest('td');
        const currentRow = active.closest('tr');
        const colIndex = Array.from(currentRow.children).indexOf(currentTd);
        const nextRow = currentRow.nextElementSibling;
        if (nextRow && nextRow.children[colIndex]) {
          const nextInput = nextRow.children[colIndex].querySelector('input');
          if (nextInput) { nextInput.focus(); nextInput.select(); }
        }
      }
    }
  });

  document.querySelectorAll('.payroll-field').forEach(input => {
    input.addEventListener('input', (e) => {
      let draft = JSON.parse(localStorage.getItem(STORAGE_KEY)) || {};
      draft[e.target.dataset.key] = e.target.value;
      localStorage.setItem(STORAGE_KEY, JSON.stringify(draft));
      document.getElementById('autosaveStatus').innerText = 'Saving...';
      setTimeout(() => { document.getElementById('autosaveStatus').innerText = 'All changes saved'; }, 500);
    });
  });

  function clearDraft() {
    if(confirm('Clear all entries?')) { localStorage.removeItem(STORAGE_KEY); location.reload(); }
  }
</script>

<%- include('../partials/footer') %>