<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<% const period = moment(`${payrollRun.year}-${String(payrollRun.month).padStart(2,'0')}-01`).format('MMMM YYYY') %>
<% const fmt = (n) => 'N$ ' + Number(n || 0).toLocaleString('en-NA', {minimumFractionDigits:2, maximumFractionDigits:2}) %>

<style>
  .nm-page-wrapper { flex:1; padding:32px 24px 48px; }
  .nm-page-inner   { max-width:1400px; margin:0 auto; } 

  .nm-page-header { display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:28px; }
  .nm-header-left { display:flex; align-items:center; gap:16px; }
  .nm-back-btn { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; background:rgba(255,255,255,0.05); color:rgba(255,255,255,0.6); text-decoration:none; transition:0.2s; }
  .nm-back-btn:hover { background:rgba(255,255,255,0.1); color:#fff; }
  .nm-page-title { font-family:'Sora',sans-serif; font-size:1.5rem; font-weight:700; color:#fff; margin:0; }
  .nm-page-subtitle { font-size:0.875rem; color:rgba(255,255,255,0.4); margin:4px 0 0; }

  .nm-btn-primary { display:inline-flex; align-items:center; gap:8px; padding:10px 20px; border-radius:9px; background:#f5a623; color:#1a0e00; font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; border:none; cursor:pointer; text-decoration:none; transition:0.2s; }
  .nm-btn-primary:hover { background:#e8981e; transform:translateY(-1px); }

  .nm-kpi-strip { display:grid; grid-template-columns:repeat(6,1fr); gap:12px; margin-bottom:24px; }
  .nm-kpi-mini { background:#0d1b2a; border:1px solid rgba(255,255,255,0.07); padding:16px; border-radius:12px; }
  .nm-kpi-label { font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; color:rgba(255,255,255,0.4); margin-bottom:8px; font-weight:600; }
  .nm-kpi-val { font-family:'Sora',sans-serif; font-weight:700; color:#fff; }
  .nm-kpi-val.lg { font-size:1.4rem; }
  .nm-kpi-val.md { font-size:1.1rem; }
  
  .c-blue   { border-left:3px solid #60a5fa; }
  .c-green  { border-left:3px solid #2ecc8a; }
  .c-teal   { border-left:3px solid #2dd4bf; }
  .c-orange { border-left:3px solid #f5a623; }
  .c-purple { border-left:3px solid #a78bfa; }
  .c-red    { border-left:3px solid #f87171; }

  .nm-panel { background:#0d1b2a; border:1px solid rgba(255,255,255,0.07); border-radius:14px; overflow:hidden; margin-bottom:24px; }
  .nm-panel-header { padding:16px 20px; background:rgba(255,255,255,0.02); border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:space-between; }
  .nm-panel-title { font-family:'Sora',sans-serif; font-size:0.95rem; font-weight:600; color:rgba(255,255,255,0.9); display:flex; align-items:center; gap:10px; }
  .nm-panel-icon { width:28px; height:28px; border-radius:6px; display:flex; align-items:center; justify-content:center; font-size:0.9rem; }
  .nm-panel-icon.blue  { background:rgba(96,165,250,0.15); color:#60a5fa; }
  .nm-panel-icon.green { background:rgba(46,204,138,0.15); color:#2ecc8a; }

  .nm-table { width:100%; border-collapse:collapse; font-size:0.82rem; }
  .nm-table thead th { padding:12px 14px; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.06em; color:rgba(255,255,255,0.35); background:#112235; text-align:left; }
  .nm-table td { padding:13px 14px; vertical-align:middle; border-bottom:1px solid rgba(255,255,255,0.04); color:rgba(255,255,255,0.7); }
  .nm-table tfoot td { padding:16px 14px; background:rgba(255,255,255,0.02); font-weight:700; color:#fff; }
  
  .nm-money { font-family:'Sora',sans-serif; font-weight:600; white-space:nowrap; }
  .nm-money.green  { color:#2ecc8a; }
  .nm-money.red    { color:#f87171; }
  .nm-money.orange { color:#f5a623; }
  .nm-money.plain  { color:rgba(255,255,255,0.9); }
  
  .nm-emp-name { font-weight:600; color:#fff; }
  .nm-sub-info { font-size:0.7rem; color:rgba(255,255,255,0.3); margin-top:2px; }
  
  .nm-pdf-btn { display:inline-flex; align-items:center; gap:5px; padding:5px 10px; border-radius:7px; border:1px solid rgba(248,113,113,0.25); background:rgba(248,113,113,0.08); color:#f87171; font-size:0.8rem; font-weight:600; text-decoration:none; transition:0.2s; }
  .nm-pdf-btn:hover { background:rgba(248,113,113,0.15); border-color:#f87171; }

  .nm-contrib-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; padding:20px; }
  .nm-contrib-card { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.05); border-radius:10px; padding:16px; }
  .nm-contrib-card.highlight { border-color:rgba(245,166,35,0.3); background:rgba(245,166,35,0.05); }
  .nm-contrib-label { font-size:0.75rem; color:rgba(255,255,255,0.4); margin-bottom:10px; }
  .nm-contrib-val { font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:700; color:#fff; }

  .nm-disclaimer { display:flex; align-items:flex-start; gap:10px; background:rgba(96,165,250,0.06); border:1px solid rgba(96,165,250,0.15); border-radius:10px; padding:15px 20px; font-size:0.82rem; color:rgba(96,165,250,0.8); line-height:1.5; }
</style>

<div class="nm-page-wrapper">
  <div class="nm-page-inner">

    <div class="nm-page-header">
      <div class="nm-header-left">
        <a href="/payroll" class="nm-back-btn"><i class="bi bi-arrow-left"></i></a>
        <div>
          <h1 class="nm-page-title"><%= period %> Payroll</h1>
          <p class="nm-page-subtitle"><%= payrollRun.employeeCount %> employees &bull; Processed <%= moment(payrollRun.processedAt).format('DD MMM YYYY') %></p>
        </div>
      </div>
      <div class="nm-header-actions">
        <a href="/payroll/<%= payrollRun._id %>/zip" class="nm-btn-primary"><i class="bi bi-file-earmark-zip-fill me-1"></i>Download All (ZIP)</a>
      </div>
    </div>

    <div class="nm-kpi-strip">
      <div class="nm-kpi-mini c-blue"><div class="nm-kpi-label">Employees</div><div class="nm-kpi-val lg"><%= payrollRun.employeeCount %></div></div>
      <div class="nm-kpi-mini c-green"><div class="nm-kpi-label">Total Gross</div><div class="nm-kpi-val md"><%= fmt(payrollRun.totalGrossPay) %></div></div>
      <div class="nm-kpi-mini c-teal"><div class="nm-kpi-label">Total Net Pay</div><div class="nm-kpi-val md"><%= fmt(payrollRun.totalNetPay) %></div></div>
      <div class="nm-kpi-mini c-orange"><div class="nm-kpi-label">Total PAYE</div><div class="nm-kpi-val md"><%= fmt(payrollRun.totalPAYE) %></div></div>
      <div class="nm-kpi-mini c-purple"><div class="nm-kpi-label">Total SSC</div><div class="nm-kpi-val md"><%= fmt(payrollRun.totalSSCEmployee + payrollRun.totalSSCEmployer) %></div></div>
      <div class="nm-kpi-mini c-red"><div class="nm-kpi-label">Total Cost</div><div class="nm-kpi-val md"><%= fmt(payrollRun.totalEmployerCost) %></div></div>
    </div>

    <div class="nm-panel">
      <div class="nm-panel-header">
        <div class="nm-panel-title"><span class="nm-panel-icon blue"><i class="bi bi-table"></i></span>Breakdown</div>
      </div>
      <div class="table-responsive">
        <table class="nm-table">
          <thead>
            <tr>
              <th>Employee</th>
              <th>Basic Salary</th>
              <th>Allowances</th> 
              <th>Gross Pay</th>
              <th>PAYE</th>
              <th>SSC (Emp)</th>
              <th>Other Deduct</th> 
              <th>Net Pay</th>
              <th class="text-end">Action</th>
            </tr>
          </thead>
          <tbody>
            <% payrollRun.payslips.forEach(ps => { %>
              <tr>
                <td>
                  <div class="nm-emp-name text-nowrap"><%= ps.employeeSnapshot?.fullName || 'Unknown' %></div>
                  <div class="nm-sub-info">ID: <%= ps.employeeSnapshot?.idNumber %></div>
                </td>
                <td><span class="nm-money plain"><%= fmt(ps.basicSalary) %></span></td>
                <td>
                  <% const totalAllow = (ps.overtimePay || 0) + (ps.taxableAllowances || 0) + (ps.nonTaxableAllowances || 0); %>
                  <span class="nm-money <%= totalAllow > 0 ? 'green' : 'plain' %>"><%= fmt(totalAllow) %></span>
                  <% if (totalAllow > 0) { %>
                    <div class="nm-sub-info">Includes Overtime & Perks</div>
                  <% } %>
                </td>
                <td><span class="nm-money plain"><%= fmt(ps.grossPay) %></span></td>
                <td><span class="nm-money red"><%= fmt(ps.paye) %></span></td>
                <td><span class="nm-money orange"><%= fmt(ps.sscEmployee) %></span></td>
                <td><span class="nm-money red"><%= fmt(ps.otherDeductions) %></span></td>
                <td><span class="nm-money green" style="font-size: 0.9rem;"><%= fmt(ps.netPay) %></span></td>
                <td class="text-end">
                  <a href="/payroll/<%= payrollRun._id %>/payslip/<%= ps._id %>/pdf" class="nm-pdf-btn">
                    <i class="bi bi-file-earmark-pdf"></i>PDF
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
          <tfoot>
            <tr>
              <td>TOTALS</td>
              <td>—</td>
              <td>—</td>
              <td><span class="nm-money plain"><%= fmt(payrollRun.totalGrossPay) %></span></td>
              <td><span class="nm-money red"><%= fmt(payrollRun.totalPAYE) %></span></td>
              <td><span class="nm-money orange"><%= fmt(payrollRun.totalSSCEmployee) %></span></td>
              <td><span class="nm-money red"><%= fmt(payrollRun.totalOtherDeductions) %></span></td>
              <td><span class="nm-money green"><%= fmt(payrollRun.totalNetPay) %></span></td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <div class="nm-panel">
      <div class="nm-panel-header">
        <div class="nm-panel-title"><span class="nm-panel-icon green"><i class="bi bi-building-fill-check"></i></span>Employer Compliance</div>
      </div>
      <div class="nm-contrib-grid">
        <div class="nm-contrib-card">
          <div class="nm-contrib-label">Social Security (Employer Portion)</div>
          <div class="nm-contrib-val"><%= fmt(payrollRun.totalSSCEmployer) %></div>
          <div class="nm-sub-info">0.9% contribution per employee</div>
        </div>
        <div class="nm-contrib-card">
          <div class="nm-contrib-label">Compensation Fund (ECF)</div>
          <div class="nm-contrib-val"><%= fmt(payrollRun.totalECF) %></div>
          <div class="nm-sub-info">Based on basic salary rates</div>
        </div>
        <div class="nm-contrib-card highlight">
          <div class="nm-contrib-label">Total Company Expenditure</div>
          <div class="nm-contrib-val" style="color: #f5a623;"><%= fmt(payrollRun.totalEmployerCost) %></div>
          <div class="nm-sub-info" style="color: rgba(245,166,35,0.6)">Gross + Employer Statutories</div>
        </div>
      </div>
    </div>

    <div class="nm-disclaimer">
      <i class="bi bi-info-circle-fill"></i>
      <div>
        <strong>Compliance Notice:</strong> This report is final. Payments for Social Security and PAYE must be settled with NamRA and the Social Security Commission by the 20th of the following month to avoid interest and penalties.
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>